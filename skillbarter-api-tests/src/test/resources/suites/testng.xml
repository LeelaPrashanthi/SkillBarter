<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SkillBarter API – FULL REGRESSION SUITE
  Runs every /api endpoint covered by the test classes in dependency order:
    auth → users → skills → matches → sessions → messages
         → notifications → reviews → calendar → transactions → stories
  Auth MUST run first because Bootstrap.ensureFirstUser() populates the
  shared token + user id in TestContext, which every later module depends on.
  Execution mode : SEQUENTIAL (thread-count="1")
-->
<suite name="SkillBarter API – Full Regression Suite" verbose="2" thread-count="1">

    <listeners>
        <listener class-name="com.cts.mfrp.skillbarter.utils.ExtentReportListener"/>
    </listeners>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 1 – AUTH  (TS_AUTH)
         POST /api/auth/register, /login, /forgot-password, /reset-password
    ══════════════════════════════════════════════════════════════ -->
    <test name="Auth API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.auth.AuthTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 2 – USERS  (TS_USERS)
         GET /api/users, GET/PUT /api/users/{id}, DELETE /api/users/{id}
    ══════════════════════════════════════════════════════════════ -->
    <test name="User API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.users.UserTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 3 – SKILLS  (TS_SKILLS)
         GET/POST /api/skills, GET/PUT/DELETE /api/skills/{id}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Skill API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.skills.SkillTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 4 – MATCHES  (TS_MATCHES)
         GET/POST /api/matches, GET /api/matches/user/{userId}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Match API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.matches.MatchTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 5 – SESSIONS  (TS_SESSIONS)
         GET/POST /api/sessions, PUT /api/sessions/{id}/complete
    ══════════════════════════════════════════════════════════════ -->
    <test name="Session API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.sessions.SessionTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 6 – MESSAGES  (TS_MESSAGES) — depends on a seeded session
         GET /api/messages/session/{sessionId}, POST /api/messages
    ══════════════════════════════════════════════════════════════ -->
    <test name="Message API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.messages.MessageTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 7 – NOTIFICATIONS  (TS_NOTIFICATIONS)
         GET /api/notifications/user/{userId}{,/unread}
         PUT /api/notifications/{id}/read, /user/{userId}/read-all
         DELETE /api/notifications/{id}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Notification API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.notifications.NotificationTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 8 – REVIEWS  (TS_REVIEWS) — depends on completed session
         GET/POST /api/reviews, GET /api/reviews/user/{userId}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Review API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.reviews.ReviewTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 9 – CALENDAR  (TS_CALENDAR)
         GET/POST /api/calendar, DELETE /api/calendar/{id}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Calendar API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.calendar.CalendarTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 10 – TRANSACTIONS  (TS_TRANSACTIONS) — depends on session
         GET/POST /api/transactions, GET /api/transactions/user/{userId}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Transaction API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.transactions.TransactionTests"/>
        </classes>
    </test>

    <!-- ══════════════════════════════════════════════════════════════
         MODULE 11 – STORIES  (TS_STORIES)
         GET/POST /api/stories, PUT/DELETE /api/stories/{id}
    ══════════════════════════════════════════════════════════════ -->
    <test name="Story API Tests" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.stories.StoryTests"/>
        </classes>
    </test>

</suite>
