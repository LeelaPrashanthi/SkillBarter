<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Parallel suite: read-only GET suites run in parallel (4 threads).
  Auth + mutating suites (Users, Sessions, Stories) run sequentially.
-->
<suite name="SkillBarter API – Parallel Suite" verbose="2"
       parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="com.cts.mfrp.skillbarter.utils.ExtentReportListener"/>
    </listeners>

    <!-- Sequential – state-mutating -->
    <test name="[S] Auth Tests"         parallel="false">
        <classes><class name="com.cts.mfrp.skillbarter.tests.auth.AuthTests"/></classes>
    </test>
    <test name="[S] User Tests"         parallel="false">
        <classes><class name="com.cts.mfrp.skillbarter.tests.users.UserTests"/></classes>
    </test>
    <test name="[S] Session Tests"      parallel="false">
        <classes><class name="com.cts.mfrp.skillbarter.tests.sessions.SessionTests"/></classes>
    </test>
    <test name="[S] Transaction Tests"  parallel="false">
        <classes><class name="com.cts.mfrp.skillbarter.tests.transactions.TransactionTests"/></classes>
    </test>

    <!-- Parallel – read-heavy -->
    <test name="[P] Skill Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.skills.SkillTests"/></classes>
    </test>
    <test name="[P] Match Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.matches.MatchTests"/></classes>
    </test>
    <test name="[P] Message Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.messages.MessageTests"/></classes>
    </test>
    <test name="[P] Notification Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.notifications.NotificationTests"/></classes>
    </test>
    <test name="[P] Review Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.reviews.ReviewTests"/></classes>
    </test>
    <test name="[P] Calendar Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.calendar.CalendarTests"/></classes>
    </test>
    <test name="[P] Story Tests">
        <classes><class name="com.cts.mfrp.skillbarter.tests.stories.StoryTests"/></classes>
    </test>

</suite>
