<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SkillBarter Automation – PARALLEL TEST SUITE
  ═══════════════════════════════════════════════════════════
  Parallel strategy  : tests   (each <test> block runs in its own thread)
  Thread count       : 4       (adjust to match available CPU cores)
  Groups suitable for parallel: smoke, regression (stateless read-only tests)

  RULES applied here:
    ✅  Stateless / read-only modules run in parallel
        (Home, SignIn, SignUp, ProfileCreation, Dashboard, Matches,
         Calendar, Progress, Community, Subscriptions, Non-Functional)

    ⛔  Stateful / session-mutating modules run SEQUENTIALLY in isolation:
        - ProfileDropdown (logout step invalidates session)
        - UserProfile     (writes to DB)
        - SavedProfiles   (removes records)
        - Messenger       (sends messages / accepts requests)
        - Transaction E2E (multi-step flows, DB mutations)
        - Notifications   (bell-click state)
  ═══════════════════════════════════════════════════════════
-->
<suite name="SkillBarter – Parallel Suite" verbose="2"
       parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="com.cts.mfrp.skillbarter.utils.ExtentReportListener"/>
    </listeners>

    <!-- ─── PARALLEL BLOCK ──────────────────────────────────────────────── -->

    <test name="[P] Home Page Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.HomePageTest"/>
        </classes>
    </test>

    <test name="[P] Sign In Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SignInTest"/>
        </classes>
    </test>

    <test name="[P] Sign Up Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SignUpTest"/>
        </classes>
    </test>

    <test name="[P] Profile Creation Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.ProfileCreationTest"/>
        </classes>
    </test>

    <test name="[P] Dashboard Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.DashboardTest"/>
        </classes>
    </test>

    <test name="[P] Matches Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.MatchesTest"/>
        </classes>
    </test>

    <test name="[P] Calendar Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.CalendarTest"/>
        </classes>
    </test>

    <test name="[P] Progress Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.ProgressTest"/>
        </classes>
    </test>

    <test name="[P] Community Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.CommunityTest"/>
        </classes>
    </test>

    <test name="[P] Subscriptions Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SubscriptionsTest"/>
        </classes>
    </test>

    <test name="[P] Non-Functional Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.NonFunctionalTest"/>
        </classes>
    </test>

    <!-- ─── SEQUENTIAL BLOCK (stateful / mutating) ───────────────────────── -->
    <!-- These run one at a time; parallel="false" is implicit per <test> here -->

    <test name="[S] Notifications Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.NotificationsTest"/>
        </classes>
    </test>

    <test name="[S] Profile Dropdown Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.ProfileDropdownTest"/>
        </classes>
    </test>

    <test name="[S] User Profile Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.UserProfileTest"/>
        </classes>
    </test>

    <test name="[S] Saved Profiles Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SavedProfilesTest"/>
        </classes>
    </test>

    <test name="[S] Messenger Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.MessengerTest"/>
        </classes>
    </test>

    <test name="[S] Transaction Flow E2E" parallel="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.TransactionFlowTest"/>
        </classes>
    </test>

</suite>
