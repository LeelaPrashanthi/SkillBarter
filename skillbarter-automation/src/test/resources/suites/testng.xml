<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SkillBarter Automation – MASTER TEST SUITE (Sequential)
  Runs 89 test methods across 14 modules in order.
  Execution mode : SEQUENTIAL (thread-count="1")
  Use parallel-testng.xml for parallel runs of the stateless subset.
-->
<suite name="SkillBarter – Full Regression Suite" verbose="2" thread-count="1">

