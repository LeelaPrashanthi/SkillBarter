<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  SkillBarter Automation – PARALLEL TEST SUITE
  ═══════════════════════════════════════════════════════════
  Parallel strategy  : tests   (each <test> block runs in its own thread)
  Thread count       : 4       (adjust to match available CPU cores)

  ONLY stateless / read-only modules are included here. Each <test> block
  spawns its own WebDriver instance, so they can safely execute concurrently.

  STATEFUL modules (Notifications, ProfileDropdown, UserProfile, SavedProfiles,
  Messenger, TransactionFlow) are intentionally EXCLUDED from this suite.
  Reason: they log out / mutate DB / accept-decline requests — running them
  concurrently against the same backend produces flaky failures. Run them via
  the master testng.xml in a sequential pass.

  TestNG note: a per-<test> `parallel="false"` attribute is NOT valid syntax
  (allowed values: methods, tests, classes, instances). To actually serialise
  a block, you must either remove it from a parallel suite or chain suites
  via <suite-files>. This file takes the first approach.
  ═══════════════════════════════════════════════════════════
-->
<suite name="SkillBarter – Parallel Suite (stateless only)" verbose="2"
       parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="com.cts.mfrp.skillbarter.utils.ExtentReportListener"/>
    </listeners>

    <!-- ─── Module 1 — Home Page (TC_001-007) ─────────────────────────────── -->
    <test name="[P] Home Page Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.HomePageTest"/>
        </classes>
    </test>

    <!-- ─── Module 2 — Sign In (TC_008-013) ───────────────────────────────── -->
    <test name="[P] Sign In Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SignInTest"/>
        </classes>
    </test>

    <!-- ─── Module 3 — Sign Up (TC_014-019) ───────────────────────────────── -->
    <test name="[P] Sign Up Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.SignUpTest"/>
        </classes>
    </test>

    <!-- ─── Module 4 — Profile Creation (TC_020-023) ──────────────────────── -->
    <test name="[P] Profile Creation Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.ProfileCreationTest"/>
        </classes>
    </test>

    <!-- ─── Module 5 — Dashboard (TC_024-032) ─────────────────────────────── -->
    <test name="[P] Dashboard Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.DashboardTest"/>
        </classes>
    </test>


    <!-- ─── Module 11 — Matches (TC_052-056) ──────────────────────────────── -->
    <test name="[P] Matches Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.MatchesTest"/>
        </classes>
    </test>

    <!-- ─── Module 13 — Calendar (TC_062-068) ─────────────────────────────── -->
    <test name="[P] Calendar Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.CalendarTest"/>
        </classes>
    </test>

    <!-- ─── Module 14 — Progress (TC_069-078) ─────────────────────────────── -->
    <test name="[P] Progress Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.ProgressTest"/>
        </classes>
    </test>

    <!-- ─── Module 15 — Community (TC_079-086) ────────────────────────────── -->
    <test name="[P] Community Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.cts.mfrp.skillbarter.tests.CommunityTest"/>
        </classes>
    </test>


    <!--
      Stateful modules excluded (run via master testng.xml):
        Module 6  — ProfileDropdown   (logout invalidates session)
        Module 7  — Notifications     (bell-click + mark-all-read mutate state)
        Module 8  — UserProfile       (writes profile changes)
        Module 9  — SavedProfiles     (removes records)
        Module 12 — Messenger         (sends messages / accepts requests)
        Module 17 — TransactionFlow   (multi-step E2E DB mutations)
    -->

</suite>
